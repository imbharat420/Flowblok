# ─────────────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Flowblok environment configuration
# Copy to `.env.local` (git-ignored) and fill in. Next.js loads it automatically.
# Every value below is OPTIONAL for local dev — with none set, the app runs on an
# embedded Postgres (PGlite) and prints email OTPs to the server console.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──
# Real Postgres connection string. When set, the app uses postgres.js against it.
# When UNSET, an embedded PGlite database is used and persisted to ./.data/pg
# (zero setup — great for local dev). Examples:
#   postgresql://user:password@localhost:5432/flowblok
#   postgresql://user:password@host/db?sslmode=require   (Neon / Supabase)
DATABASE_URL=

# ── Security ──
# 32+ char secret used to derive the AES-256-GCM key that encrypts credential
# secrets at rest. REQUIRED in production. Generate: `openssl rand -base64 48`
CRED_SECRET=

# Session lifetime in days for the auth cookie (default 30).
SESSION_TTL_DAYS=30

# ── Seed admin (created on first boot so you can sign in immediately) ──
SEED_ADMIN_EMAIL=admin@flowblok.dev
SEED_ADMIN_PASSWORD=flowblok-admin-2026

# ── Email (verification OTP) ──
# With RESEND_API_KEY set, OTP emails are sent via Resend. Without it, the code
# is logged to the server console (dev mode) and surfaced in the verify UI.
RESEND_API_KEY=
EMAIL_FROM="Flowblok <onboarding@flowblok.dev>"

# Public base URL of the app. Reserved for absolute links in emails — not yet
# referenced in code (verification emails currently contain the code only).
APP_URL=http://localhost:3100

# ── AI (optional) ──
# Used by the AI Agent workflow node. Without it, the node returns a simulated
# reply so workflows still run end-to-end.
ANTHROPIC_API_KEY=
